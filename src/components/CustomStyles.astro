---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
    overscroll-behavior: none;
  }

  header[data-aw-sticky-header] > .absolute.inset-0 {
    background-color: rgba(255, 255, 255, 0.2) !important;
  }

  @media (max-width: 767px) {
    header[data-aw-sticky-header] > .absolute.inset-0 {
      background-color: rgb(255, 255, 255) !important;
    }
  }

  header {
    position: fixed;
    z-index: 9999;
  }

  body {
    background-image: url('/assets/images/bg.JPG');
    background-size: cover;
    background-position: top;
    background-repeat: no-repeat;
    background-attachment: fixed;

    letter-spacing: 0.08em;
  }

  .parallax-layer {
    will-change: transform;
    pointer-events: none;
  }

  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(255, 255, 255);
    --aw-color-secondary: rgb(255, 255, 255);
    --aw-color-accent: rgb(255, 255, 255);

    --aw-color-text-heading: rgb(255, 167, 252);
    --aw-color-text-default: rgb(255, 255, 255);
    --aw-color-text-muted: rgba(255, 255, 255);
    --aw-color-bg-page: rgb(216, 152, 255);

    --aw-color-bg-page-dark: rgb(255, 255, 255);

    ::selection {
      background-color: rgb(162, 162, 255);
    }
  }
</style>
