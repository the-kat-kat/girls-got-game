---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Steps from '~/components/widgets/Steps.astro';

const metadata = {
  title: 'Home',
  ignoreTitleTemplate: false,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Join Our Discord',
        href: 'https://discord.gg/wTFtv2rnCW',
      },
      {
        variant: 'primary',
        text: 'Register',
        href: 'https://forms.gle/m7MqqCkAZTbXp4Xi7',
      },
    ]}
    image={{ src: '~/assets/images/arrow2.png', alt: 'Girls Got Game Hero Image' }}
  >
    <Fragment slot="bg">
      <img src="/assets/images/gggpink.png" alt="" class="w-full h-auto object-contain" />
    </Fragment>

    <Fragment slot="title"> </Fragment>

    <Fragment slot="subtitle">
      <span class="text-white leading-none">
        An international game jam empowering female and <br /> non-binary students in technology and innovation through game
        development <br />June 15th - 22nd, 2026<br /><br />
      </span>
    </Fragment>
  </Hero>

  <main class="space-y-40">
    <!-- Features Widget *************** -->
    <section id="About" class="intersect animate-fade">
      <Features
        id="features"
        title="About"
        subtitle={`Girls Got Game is an international online game jam designed to empower <span class='text-yellow-400'> girls and nonbinary youths ages 13–18</span> to explore creativity, coding, and storytelling through game development. Whether you're new to games or already creating, this beginner-friendly event offers resources, and a supportive community to build and share your own game. This summer, Girls Got Game is running our third game jam, running from June 15th to June 22nd 2026!`}
      />
    </section>

    <section id="Game-Jam" class="intersect animate-fade">
      <Features
        id="features"
        title="What is a Game Jam?"
        subtitle="A game jam is a fun, short-term event where people come together to make games based on a surprise theme (ex: “growth” or “light and shadow”). You don’t need experience, just creativity and a willingness to try! Over a few days, you’ll design and build a simple game (on your own or with a team), and then share it with others at the end."
      />
    </section>

    <section id="HIW" class="intersect animate-fade">
      <Steps
        title="How to Participate"
        items={[
          {
            title: 'Register Online',
            description:
              'Sign up individually using the google form <a href="https://forms.gle/LriwRZLesKgWaiYA7" target="_blank" rel="noopener noreferrer"><strong><u>here</u></strong></a> and join the community on <a href="https://discord.gg/wTFtv2rnCW" target="_blank" rel="noopener noreferrer"><strong><u>Discord</u></strong></a> to stay up to date on important information! [Disclaimer: we verify all Discord members to ensure a secure and enjoyable experience for all.] If you want to join a team, there will be a separate form for that after you register individually.',
          },
          {
            title: 'Join the Kickoff (June 15th)',
            description:
              'We’ll announce the theme (a phrase to inspire your game), share resources, and answer questions',
          },
          {
            title: 'Make Your Game',
            description:
              'You’ll have one week to create a game based on the theme. Use any tool or platform (ex: Scratch, Unity, Godot, and more)! It’s not just programming though, you can also participate as part of a team by contributing art, music, or design!',
          },
          {
            title: 'Celebrate',
            description: 'Explore what others made, and celebrate your creativity in our closing showcase!',
          },
        ]}
      />
    </section>

    <section id="Criteria" class="intersect animate-fade">
      <!-- FAQ Widget **************** -->
      <FAQs
        title="Judging Criteria"
        subtitle="Games will be judged based on the following 4 criteria:"
        items={[
          {
            title: 'Theme',
            description: 'Does the game use the official theme in a meaningful way?',
          },
          {
            title: 'Gameplay',
            description: 'Is the game fun and engaging?',
          },
          {
            title: 'Quality',
            description: 'Is the game complete and polished?',
          },
          {
            title: 'Creativity',
            description: 'Does the game incorporate fresh ideas in its design?',
          },
        ]}
      />
    </section>

    <!-- Features Widget ***************   -->

    <section id="Rules" class="intersect animate-fade py-12 px-4">
      <div class="max-w-5xl mx-auto rounded-3xl p-8 shadow-md" style="background-color: rgba(22, 17, 68, 0.5);">
        <h2 class="text-4xl font-bold text-center mb-8 text-white">Rules</h2>
        <ol class="list-decimal list-inside space-y-4 text-lg">
          <li>Games must be submitted by <strong>June 22nd @ 11:59 pm PST</strong>.</li>
          <li>
            Games must be created using a free or open platform (ex: Scratch, Twine, Construct, Godot, Bitsy, Unity). If
            you are unsure, ask in the Discord or email us at <a
              href="mailto:hello@girlsgotgamejam.org"
              class="underline">hello@girlsgotgamejam.org</a
            >!
          </li>
          <li>Minimal use of AI for code is allowed, but you must describe how it was used in the submission form.</li>
          <li>
            You must provide additional submission information at <a
              href="https://forms.gle/ERNRn2LWzSBCqSVz6"
              target="_blank"
              class="underline">this form</a
            >. This includes:
            <ul class="list-disc list-inside ml-6 space-y-1">
              <li>A link to your submitted itch.io page</li>
              <li>
                A 2-3 sentence description of what inspired you to create the game and what you learned in the process
              </li>
              <li>A 1-2 minute video of you playing the game (voiceover optional)</li>
            </ul>
          </li>
          <li>
            You may create original assets (art, music, sound, etc.) or use free online assets as long as they are
            properly credited. <strong>Assets may not be created using AI.</strong>
          </li>
          <li>
            Your game must be based on the official theme. You can interpret the theme in any creative way that is
            meaningful in your game!
          </li>
          <li>
            You may not have started work on the game you submit prior to the jam start date, <strong
              >June 15th 2026</strong
            >.
          </li>
        </ol>
      </div>
    </section>

    <section id="FAQ" class="intersect animate-fade">
      <!-- FAQ Widget **************** -->
      <FAQs
        title="Frequently Asked Questions"
        items={[
          {
            title: 'What is a Game Jam?',
            description: 'A game jam is a short event where people collaborate to create video games!',
          },
          {
            title: 'Who can participate?',
            description:
              'Girls Got Game is open to girls and non-binary youth ages 13–18 from anywhere in the world. No prior experience is required.',
          },
          {
            title: 'Is there a fee?',
            description: 'No, participating in Girls Got Game is free :)',
          },
          {
            title: 'Do I need to know how to code?',
            description:
              'Nope, beginners are welcome! We’ll share resources to help you get started. You can also participate in a team by contributing art, music, or design.',
          },
          {
            title: 'Can I work in a team?',
            description:
              'Yes! You can participate solo or in a team of up to 4 people. You’ll be able to register as a team after you sign up individually. We’ll also help match solo participants who want to find teammates.',
          },
          {
            title: 'Do I need Discord?',
            description:
              'Discord is optional but highly recommended. It’s where we’ll host announcements and community chats. We’ll have moderators to keep things safe and supportive. You can join <a href="https://discord.gg/TgweDKk2" target="_blank" rel="noopener noreferrer"><strong><u>here</u></strong></a>.',
          },
          {
            title: 'Where can I ask more questions?',
            description:
              'You can ask a question on our Discord server or email us directly at <span class="text-yellow-400"> hello@girlsgotgamejam.org</span>. We’re happy to help!',
          },
        ]}
      />
    </section>

    <!-- CallToAction Widget *********** -->
    <section id="Register" class="intersect animate-fade">
      <CallToAction
        actions={[
          {
            variant: 'primary',
            text: 'Register Now',
            href: 'https://forms.gle/m7MqqCkAZTbXp4Xi7',
            target: '_blank',
          },
          {
            variant: 'primary',
            text: 'Join Our Discord',
            href: 'https://discord.gg/wTFtv2rnCW',
          },
        ]}
      >
        <Fragment slot="title"> Ready to join? </Fragment>
      </CallToAction>
    </section>

    <!--paralax scroll-->
    <script is:inline>
      let parallaxFactor;

      if (window.innerWidth < 500) {
        parallaxFactor = 0.05; // mobile
      } else if (window.innerWidth < 1025) {
        parallaxFactor = 0; // tablet
      } else {
        parallaxFactor = 0.3; // desktop
      }

      if (window.innerWidth > 0) {
        window.addEventListener('scroll', () => {
          const scrollTop = window.pageYOffset;

          const far = document.querySelector('.parallax-far');
          const mid = document.querySelector('.parallax-mid');
          const midnear = document.querySelector('.parallax-midnear');
          const near = document.querySelector('.parallax-near');

          if (far) {
            far.style.transform = `translateY(${(-scrollTop * 80 * parallaxFactor) / window.innerWidth}px)`;
          }
          if (mid) {
            mid.style.transform = `translateY(${(-scrollTop * 200 * parallaxFactor) / window.innerWidth}px)`;
          }
          if (midnear) {
            midnear.style.transform = `translateY(${(-scrollTop * 400 * parallaxFactor) / window.innerWidth}px)`;
          }
          if (near) {
            near.style.transform = `translateY(${(-scrollTop * 600 * parallaxFactor) / window.innerWidth}px)`;
          }
        });
      }
    </script>
  </main>
</Layout>
