---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Supporters',
};

const supporters = [
  {
    name: 'Code Coven',
    subtitle: 'Empowering marginalized developers',
    logo: '/assets/images/construct3.jpg',
  },
];
---

<Layout metadata={metadata}>
  <HeroText title="Thank you to all our supporters!" />

  <section class="py-16 px-4 md:px-12 lg:px-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-12 items-start justify-center">
      {
        supporters.map((supporter) => (
          <div class="flex flex-col items-center text-center space-y-4">
            <img src={supporter.logo} alt={supporter.name + ' logo'} class="w-32 h-auto object-contain" />
            <div>
              <h3 class="text-lg font-semibold">{supporter.name}</h3>
              <p class="text-sm text-white">{supporter.subtitle}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
